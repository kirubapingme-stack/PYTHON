class area:
    value="the final value"
    
    def __init__(self):
        x=int(input("enter length: "))
        y=int(input("enter breadth: "))
        self.a=x
        self.b=y
    def display(self):
        return self.a*self.b
            
n=int(input("Enter no of rectangle: "))
l=[]
for i in range(n):
    r=area()
    l.append(r)
for i in l:
    print("area:",i.display())
