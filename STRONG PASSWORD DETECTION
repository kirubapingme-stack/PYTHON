p=(input("enter a password:"))
a=0
b=0
c=0
d=0
if (len(p)>7):
    for i in p:
        if i.isdigit():
            a=a+1
        elif i.isupper():
            b=b+1
        elif i.islower():
            c=c+1
        else:
            d=d+1
    if a>0 and b>0 and c>0 and d>0:
        print("nalla password")
    else:
        print("nalla ila")
else:
    print("peria password  aa podu ra")
