
def one(i,j):
    return gcd(i,j)==1
def gcd(i,j):
    while(j!=0):
        rem=i%j
        temp=j 
        j=rem
        i=temp
    return i
        
        
n=int(input("Enter a number: "))  

for i in range (5,n):
    for j in range(4,i):
        for k in range(3,j):
            if k*k+j*j==i*i and one(i,j) and one(k,i) and one(j,i):
                print(i,j,k)
              
